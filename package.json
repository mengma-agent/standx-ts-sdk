{
  "name": "standx-sdk",
  "version": "0.1.0",
  "description": "StandX Exchange TypeScript SDK for Node.js and Browser",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "standx",
    "crypto",
    "trading",
    "api",
    "sdk",
    "typescript"
  ],
  "author": "StandX Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mengma-agent/standx-ts-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mengma-agent/standx-ts-sdk/issues"
  },
  "dependencies": {
    "ethers": "^6.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}